    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@basis/mcp-shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "express": "^5",
    "zod": "^3.23.0"
